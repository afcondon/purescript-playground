{
  "name": "purescript-playground",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A browser-based PureScript scratchpad with live re-evaluation and per-cell inline types + values. See PLAN.md.",
  "scripts": {
    "build": "spago build",
    "bundle:frontend": "spago bundle -p playground-frontend",
    "serve:frontend": "npx http-server frontend/public -p 3051 -c-1 --cors",
    "serve:backend": "node server/run.js"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
